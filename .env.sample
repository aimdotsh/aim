# Copy to .env and change every value before first startup.
AIM_ADMIN_USER=admin
AIM_ADMIN_PASSWORD=replace-with-at-least-12-characters
AIM_HTTPS_PORT=8443
AIM_MAX_UPLOAD_BYTES=2147483648
# Optional in restricted networks: https://goproxy.cn,direct
AIM_GOPROXY=https://proxy.golang.org,direct
TZ=Asia/Shanghai
